# 複製為 .env 後填入實際值（.env 已被 .gitignore 排除，絕不追蹤）

# Zeabur PostgreSQL（Phase 0 起必要）
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME"

# 幹部登入 session 簽章金鑰（Phase 4 起必要，≥16 字元；正式環境務必用長亂數）
# 產生：node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=""

# Cloudflare R2（Phase 5 檢核文件上傳）
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# LLM 加強層（可選；留空＝關閉，免費規則層不受影響）
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# 提醒管道（Phase 4）
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""
LINE_GROUP_ID=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
